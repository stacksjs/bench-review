{
  "name": "bench-review",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "A judge review application powered by Stacks",
  "scripts": {
    "dev": "bun --watch serve.ts",
    "build": "bun build.ts",
    "build:stacks": "./buddy build",
    "preview": "bun preview.ts",
    "start": "bun serve.ts",
    "lint": "bunx --bun pickier .",
    "lint:fix": "bunx --bun pickier . --fix",
    "typecheck": "bun tsc --noEmit"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "ofetch": "^1.5.1",
    "perfect-debounce": "^2.1.0",
    "pretty-bytes": "^7.1.0",
    "stacks": "workspace:*",
    "ts-broadcasting": "^0.0.4"
  },
  "devDependencies": {
    "bun-git-hooks": "^0.3.1"
  },
  "workspaces": [
    "storage/framework/**",
    "!**/node_modules/**",
    "!**/dist/**",
    "!storage/framework/server/storage/**",
    "!storage/framework/cache/**"
  ],
  "git-hooks": {
    "pre-commit": {
      "staged-lint": {
        "*.{js,ts,json,yaml,yml,md}": "bunx --bun pickier lint --fix"
      }
    },
    "commit-msg": "bunx gitlint --edit .git/COMMIT_EDITMSG"
  }
}
