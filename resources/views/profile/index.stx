              <StxLink to="/review" class="inline-flex items-center px-4 py-2 font-medium text-white text-sm bg-purple-700 rounded-lg">Write a review</StxLink>
            </div>
          </div>
        </div>
      </div>

      <div class="grid gap-4 grid-cols-2 mt-8 lg:grid-cols-4">
