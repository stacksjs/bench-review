        <!-- Suggested judges -->
        <div class="p-6 bg-white border border-gray-200 rounded-2xl">
          <h2 class="font-semibold text-base text-gray-900">Review next</h2>
          <p class="mt-1 text-gray-500 text-sm">Judges to consider reviewing.</p>
          <ul class="mt-5 space-y-4">
            <li class="flex gap-3 items-center">
              <img class="object-cover flex-none h-10 w-10 rounded-full" src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=160&h=160&fit=facearea&facepad=2&auto=format" alt="Hon. Sarah Johnson" />
              <div class="flex-1 min-w-0">
                <p class="font-medium text-gray-900 text-sm truncate">Hon. Sarah Johnson</p>
                <p class="text-gray-500 text-xs truncate">Superior Court of California</p>
              </div>
              <StxLink to="/judges/123/reviews" class="flex-none px-2.5 py-1 font-medium text-purple-700 text-xs bg-purple-50 rounded-md">Review</StxLink>
            </li>
            <li class="flex gap-3 items-center">
              <img class="object-cover flex-none h-10 w-10 rounded-full" src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=160&h=160&fit=facearea&facepad=2&auto=format" alt="Hon. Robert Davis" />
              <div class="flex-1 min-w-0">
                <p class="font-medium text-gray-900 text-sm truncate">Hon. Robert Davis</p>
