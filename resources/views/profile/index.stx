            <div class="flex gap-4 items-center">
              <img class="h-24 w-24 rounded-full" x-src="avatarUrl()" />
              <div>
                <h1 class="font-bold text-2xl text-white" :text="displayName()"></h1>
                <p class="text-purple-100 text-sm" :text="memberSince()"></p>
                <div class="flex gap-2 mt-3">
                  <span class="inline-flex items-center px-2.5 py-0.5 font-medium text-purple-900 text-xs bg-purple-100 rounded-full">Trusted Reviewer</span>
                  <span class="inline-flex items-center px-2.5 py-0.5 font-medium text-purple-900 text-xs bg-purple-100 rounded-full">Verified</span>
                </div>
