<script client>
  import type { AdminReviewRow, ReviewStatusFilter } from '~/resources/stores/adminReviews'

  const store = useStore('adminReviews')

  let hasFetched = false
  function bootstrap(): void {
    if (hasFetched) return
    hasFetched = true
    store.perPage.set(25)
    store.page.set(1)
    // Default the moderator view to pending — that's the queue depth
    // they care about. The status query-param (set by the dashboard
    // CTA "Open moderation queue") overrides if present.
    if (typeof window !== 'undefined') {
      const fromUrl = new URLSearchParams(window.location.search).get('status')
      if (fromUrl === 'all' || fromUrl === 'pending' || fromUrl === 'published' || fromUrl === 'rejected')
        store.statusFilter.set(fromUrl as ReviewStatusFilter)
    }
    store.fetchReviews()
  }
  bootstrap()
  onMount(() => { bootstrap() })

  // Expanded row state — single open at a time keeps the layout calm.
  // Because only one row is open, a single response-draft signal is enough
  // (no per-row state-map needed); it's seeded from the row on expand.
  const expandedId = state<number>(0)
  const responseDraft = state<string>('')
  const savingResponse = state<boolean>(false)
  // In-flight guard for the per-row Approve/Reject/Delete mutations.
  // The buttons live inside the :for, where signal call-syntax in
  // x-disabled/:text is the forbidden footgun (silently breaks the
  // loop), so this is used purely as a JS re-entry guard to stop
  // rapid double-clicks double-firing. No per-row visual binding.
  const mutatingId = state<number | null>(null)
  function toggleExpand(review: AdminReviewRow): void {
    const opening = expandedId() !== review.id
    expandedId.set(opening ? review.id : 0)
    if (opening)
      responseDraft.set(review.response ?? '')
  }

  // Judge right-of-reply (admin-mediated). Post/replace or remove the
  // judge's official response to a review; both update the row in place.
  async function saveResponse(review: AdminReviewRow): Promise<void> {
    if (savingResponse())
      return
    savingResponse.set(true)
    await store.postResponse(review.id, responseDraft())
    savingResponse.set(false)
  }
  async function removeResponse(review: AdminReviewRow): Promise<void> {
    if (typeof window === 'undefined')
      return
    if (!window.confirm('Remove the judge\'s official response to this review?'))
      return
    if (await store.deleteResponse(review.id))
      responseDraft.set('')
  }

  function setFilter(next: ReviewStatusFilter): void {
    expandedId.set(0)
    store.setStatusFilter(next)
  }

  async function approve(review: AdminReviewRow): Promise<void> {
    if (mutatingId()) return
    mutatingId.set(review.id)
    try {
      await store.setReviewStatus(review.id, 'published')
    }
    finally {
      mutatingId.set(null)
    }
  }
  async function reject(review: AdminReviewRow): Promise<void> {
    if (mutatingId()) return
    mutatingId.set(review.id)
    try {
      await store.setReviewStatus(review.id, 'rejected')
    }
    finally {
      mutatingId.set(null)
    }
  }
  async function confirmDelete(review: AdminReviewRow): Promise<void> {
    if (typeof window === 'undefined') return
    if (mutatingId()) return
    const ok = window.confirm(`Delete review "${review.title}"? This cannot be undone.`)
    if (!ok) return
    mutatingId.set(review.id)
    try {
      await store.deleteReview(review.id)
    }
    finally {
      mutatingId.set(null)
    }
  }

  function onSearchInput(e: Event): void {
    const value = (e.target as HTMLInputElement).value
    store.setSearch(value)
  }

  function nextPage(): void {
    if (store.page() < store.totalPages())
      store.setPage(store.page() + 1)
  }
  function prevPage(): void {
    if (store.page() > 1)
      store.setPage(store.page() - 1)
  }

  function formatDate(s: string | null | undefined): string {
    if (!s) return ''
    const d = new Date(s)
    if (Number.isNaN(d.getTime())) return ''
    return d.toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' })
  }

  // Empty-state copy — derived so the message reads naturally for
  // the current filter and search. Composed of two lines: a short
  // headline + a quieter hint underneath. Branches on search query
  // first (search dominates filter), then on status.
  const emptyTitle = derived<string>(() => {
    const q = store.query().trim()
    if (q) return `No reviews match "${q}"`
    const status = store.statusFilter()
    if (status === 'pending') return 'No pending reviews'
    if (status === 'published') return 'No published reviews yet'
    if (status === 'rejected') return 'No rejected reviews'
    return 'No reviews yet'
  })
  const emptyHint = derived<string>(() => {
    if (store.query().trim()) return 'Try a different search term or clear the search.'
    const status = store.statusFilter()
    if (status === 'pending') return 'New submissions land here for moderation. You\'re all caught up.'
    if (status === 'published') return 'Approve a pending review to populate this list.'
    if (status === 'rejected') return 'Reviews you\'ve declined show up here.'
    return 'Submissions appear here once users start writing.'
  })

  // Filter tabs definition. Static — order is the order of importance
  // to a moderator (pending first because that's the queue depth).
  const TABS: Array<{ key: ReviewStatusFilter, label: string }> = [
    { key: 'pending', label: 'Pending' },
    { key: 'published', label: 'Published' },
    { key: 'rejected', label: 'Rejected' },
    { key: 'all', label: 'All' },
  ]
</script>

<div class="space-y-4">
  <div class="flex justify-between items-end">
    <div>
      <h1 class="font-bold text-2xl text-gray-900">Reviews</h1>
      <p class="mt-1 text-gray-600 text-sm">
        <span :text="store.total()"></span> <span :text="store.statusFilter()"></span>
      </p>
    </div>
    <div>
      <label for="reviews-search" class="sr-only">Search reviews</label>
      <input
        id="reviews-search"
        type="text"
        placeholder="Search title or content…"
        @input="onSearchInput($event)"
        class="block px-3 py-2 sm:w-72 text-gray-900 sm:text-sm placeholder:text-gray-400 bg-white border-0 ring-1 ring-gray-200 ring-inset rounded-md focus:ring-2 focus:ring-gray-600 focus:ring-inset"
      >
    </div>
  </div>

  <div class="flex gap-x-1 border-b border-gray-200">
    <button
      :for="tab in TABS"
      type="button"
      @click="setFilter(tab.key)"
      class="px-4 py-2 font-medium text-sm border-b-2 transition-colors"
      x-class="store.statusFilter() === tab.key ? 'border-gray-900 text-gray-900' : 'border-transparent text-gray-500 hover:text-gray-900 hover:border-gray-300'"
      :text="tab.label"
    ></button>
  </div>

  <div
    role="alert"
    class="px-4 py-3 text-red-800 text-sm bg-red-50 border border-red-200 rounded-md"
    x-class="store.actionError() ? '' : 'hidden'"
    :text="store.actionError()"
  ></div>

  <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
    <div :if="store.loading() && store.reviews().length === 0" class="px-4 py-12 text-center text-gray-500 text-sm">
      Loading reviews…
    </div>
    <!-- Empty state. x-class hidden (not :if) so the inner :text
         bindings stay subscribed across status / query changes —
         bindIf's remove/re-add cycle drops bindings on the re-add
         (same footgun the login form hit; see login.stx). -->
    <div
      class="px-6 py-16 text-center"
      x-class="!store.loading() && store.reviews().length === 0 ? '' : 'hidden'"
    >
      <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-gray-50">
        <svg class="h-6 w-6 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 12h6m-6 4h6M7 4h10a2 2 0 012 2v12a2 2 0 01-2 2H7a2 2 0 01-2-2V6a2 2 0 012-2z" />
        </svg>
      </div>
      <p class="font-semibold text-gray-900 text-sm" :text="emptyTitle()"></p>
      <p class="mt-1 max-w-md mx-auto text-gray-500 text-xs leading-relaxed" :text="emptyHint()"></p>
    </div>
    <!-- x-class hidden (not :if) so the inner :for keeps its
         subscription across the loading -> loaded transition. The
         :if remove/re-add cycle drops the :for binding on re-add and
         the rows never render even after reviews() populates. -->
    <ul x-class="store.reviews().length > 0 ? 'divide-gray-100 divide-y' : 'hidden'">
      <li :for="review in store.reviews" class="px-4 py-4">
        <div class="flex justify-between gap-x-4">
          <div class="flex-1 min-w-0">
            <div class="flex gap-x-2 items-center">
              <span
                class="inline-block px-2 py-0.5 font-medium text-xs rounded-full"
                x-class="review.status === 'published' ? 'bg-emerald-100 text-emerald-800' : review.status === 'rejected' ? 'bg-red-100 text-red-800' : 'bg-amber-100 text-amber-800'"
                :text="review.status"
              ></span>
              <span class="text-gray-500 text-xs" :text="formatDate(review.created_at)"></span>
            </div>
            <h3 class="mt-1 font-semibold text-gray-900 text-base" :text="review.title"></h3>
            <p class="mt-1 text-gray-600 text-sm">
              <span :text="review.judge.name"></span>
              <span class="text-gray-400"> · </span>
              <span :if="review.user" :text="review.user ? review.user.email : ''"></span>
              <span :if="!review.user" class="text-gray-400">(anonymous)</span>
              <span class="text-gray-400"> · </span>
              <span :text="'★ ' + review.rating"></span>
            </p>
          </div>
          <div class="flex flex-shrink-0 flex-col gap-y-1 items-end">
            <div class="flex gap-x-2">
              <button
                type="button"
                @click="approve(review)"
                x-disabled="review.status === 'published'"
                class="px-2.5 py-1 font-medium text-emerald-800 text-xs bg-emerald-50 border border-emerald-200 rounded hover:bg-emerald-100 disabled:opacity-40 disabled:cursor-not-allowed"
              >Approve</button>
              <button
                type="button"
                @click="reject(review)"
                x-disabled="review.status === 'rejected'"
                class="px-2.5 py-1 font-medium text-amber-800 text-xs bg-amber-50 border border-amber-200 rounded hover:bg-amber-100 disabled:opacity-40 disabled:cursor-not-allowed"
              >Reject</button>
              <button
                type="button"
                @click="confirmDelete(review)"
                class="px-2.5 py-1 font-medium text-red-800 text-xs bg-red-50 border border-red-200 rounded hover:bg-red-100"
              >Delete</button>
            </div>
            <button
              type="button"
              @click="toggleExpand(review)"
              class="text-gray-500 text-xs hover:text-gray-900"
              :text="expandedId() === review.id ? 'Hide content' : 'Show content'"
            ></button>
          </div>
        </div>
        <div class="mt-3 space-y-3" x-class="expandedId() === review.id ? '' : 'hidden'">
          <div class="px-4 py-3 bg-gray-50 rounded prose prose-sm max-w-none" x-html="review.content"></div>

          <!-- Judge right-of-reply composer. Posted on the judge's behalf
               (admin-mediated); renders publicly under the review. -->
          <div class="px-4 py-3 border border-amber-200 rounded bg-amber-50/40">
            <label class="block font-semibold text-amber-800 text-xs tracking-wide uppercase">Judge's official response (right-of-reply)</label>
            <p class="mt-0.5 text-gray-500 text-xs">Posted on the judge's behalf. Shows publicly under the review.</p>
            <textarea
              x-model="responseDraft"
              rows="4"
              placeholder="Enter the judge's official response…"
              class="block mt-2 px-3 py-2 w-full text-gray-900 text-sm bg-white border border-gray-300 rounded-md focus:border-gray-900 focus:outline-none focus:ring-2 focus:ring-gray-200"
            ></textarea>
            <div class="flex gap-x-2 mt-2">
              <button
                type="button"
                @click="saveResponse(review)"
                x-disabled="savingResponse"
                class="inline-flex items-center justify-center px-3 py-1.5 font-semibold text-white text-xs bg-gray-900 hover:bg-gray-800 rounded disabled:opacity-50"
              >
                <svg :if="savingResponse()" class="animate-spin -ml-0.5 mr-2 h-4 w-4" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" class="opacity-25"></circle><path d="M4 12a8 8 0 018-8" stroke="currentColor" stroke-width="3" stroke-linecap="round"></path></svg>
                <span :text="savingResponse() ? 'Saving…' : 'Save response'"></span>
              </button>
              <button
                type="button"
                @click="removeResponse(review)"
                x-class="review.response ? '' : 'hidden'"
                class="px-3 py-1.5 font-medium text-red-700 text-xs bg-white border border-red-200 rounded hover:bg-red-50"
              >Remove</button>
            </div>
          </div>
        </div>
      </li>
    </ul>
  </div>

  <div class="flex justify-between items-center">
    <p class="text-gray-500 text-sm">
      Page <span :text="store.page()"></span> of <span :text="store.totalPages()"></span>
    </p>
    <div class="flex gap-x-2">
      <button
        type="button"
        @click="prevPage()"
        x-disabled="store.page() <= 1"
        class="px-3 py-1.5 font-medium text-gray-700 text-sm bg-white border border-gray-300 rounded hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed"
      >Previous</button>
      <button
        type="button"
        @click="nextPage()"
        x-disabled="store.page() >= store.totalPages()"
        class="px-3 py-1.5 font-medium text-gray-700 text-sm bg-white border border-gray-300 rounded hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed"
      >Next</button>
    </div>
  </div>
</div>
